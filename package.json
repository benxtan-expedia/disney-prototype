{
  "type": "module",
  "name": "react-skeleton-app",
  "version": "1.0.0",
  "description": "A beginner-friendly React skeleton app with SSR, MobX, and TypeScript",
  "packageManager": "pnpm@10.6.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": "^9.0.0"
  },
  "main": "dist/server.js",
  "scripts": {
    "build:client": "webpack --config webpack.client.js && vite build --outDir dist/client",
    "build:server": "webpack --config webpack.server.js",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist/server.js",
    "dev": "node server"
  },
  "keywords": [
    "react",
    "ssr",
    "mobx",
    "hapi",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@googlemaps/markerclusterer": "^2.6.2",
    "@hapi/hapi": "^21.3.2",
    "@hapi/inert": "^7.1.0",
    "@loadable/component": "^5.16.4",
    "@loadable/server": "^5.16.4",
    "@vis.gl/react-google-maps": "^1.8.2",
    "@vitejs/plugin-react": "^2.1.0",
    "express": "^5.2.1",
    "framer-motion": "11.1.7",
    "mobx": "^6.12.0",
    "mobx-react-lite": "^4.0.5",
    "motion": "^12.38.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.1.8"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@loadable/babel-plugin": "^5.16.1",
    "@loadable/webpack-plugin": "^5.15.2",
    "@types/hapi__hapi": "^20.0.13",
    "@types/hapi__inert": "^5.2.10",
    "@types/loadable__component": "^5.13.9",
    "@types/loadable__server": "^5.12.11",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.52",
    "@types/react-dom": "^18.2.18",
    "@types/styled-components": "^5.1.34",
    "babel-loader": "^9.1.3",
    "babel-plugin-styled-components": "^2.1.4",
    "css-loader": "^7.1.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vite": "^3.1.4",
    "vite-plugin-babel": "^1.6.0",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  }
}
